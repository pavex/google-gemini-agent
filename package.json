{
  "name": "pavex-google-gemini-agent",
  "version": "1.0.0",
  "description": "Gemini agent CLI using Vercel AI SDK",
  "main": "bundle/agent.js",
  "scripts": {
    "build": "esbuild src/agent.js --bundle --platform=node --target=node20 --outfile=bundle/agent.js --minify && esbuild src/models.js --bundle --platform=node --target=node20 --outfile=bundle/models.js --minify",
    "build:dev": "esbuild src/agent.js --bundle --platform=node --target=node20 --outfile=bundle/agent.js --sourcemap && esbuild src/models.js --bundle --platform=node --target=node20 --outfile=bundle/models.js",
    "build:agent": "esbuild src/agent.js --bundle --platform=node --target=node20 --outfile=bundle/agent.js --minify",
    "build:models": "esbuild src/models.js --bundle --platform=node --target=node20 --outfile=bundle/models.js --minify",
    "start": "node bundle/agent.js",
    "dev": "npm run build:dev && node bundle/agent.js"
  },
  "author": "pavex@ines.cz",
  "license": "ISC",
  "dependencies": {
    "ai": "^6.0.141",
    "@ai-sdk/google": "^1.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "esbuild": "^0.25.9"
  },
  "keywords": [],
  "type": "commonjs"
}
